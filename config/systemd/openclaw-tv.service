[Unit]
Description=OpenClaw TV Avatar Web Server
Documentation=https://github.com/brtdwchtr/openclaw-tv
After=network.target

[Service]
Type=simple
User=PI_USER
WorkingDirectory=INSTALL_DIR
Environment=OPENCLAW_TV_DIR=INSTALL_DIR
ExecStart=INSTALL_DIR/venv/bin/python INSTALL_DIR/server/server.py --dir INSTALL_DIR
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
